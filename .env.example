# Firebase — get from Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Shared household ID — generate once with: node -e "console.log(crypto.randomUUID())"
# Both users must build with the SAME value so they share the same data.
VITE_HOUSEHOLD_ID=
